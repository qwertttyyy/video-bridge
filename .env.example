# Публичный IP сервера (обязательно)
SERVER_IP=123.45.67.89

# Доменное имя (обязательно)
SERVER_DOMAIN=video.qwertttyyy.ru

# Секрет для эфемерных TURN-кредов (обязательно).
# Сгенерировать: openssl rand -hex 32
TURN_SECRET=replace_me_with_long_random_hex

# Realm для TURN-сервера (обязательно, обычно совпадает с доменом)
TURN_REALM=video.qwertttyyy.ru

# Разрешённый origin для CORS бэкенда (обязательно, без слэша в конце)
FRONTEND_ORIGIN=https://video.qwertttyyy.ru

# Максимальное количество одновременных сессий
MAX_SESSIONS=10

# Лимит создания сессий (slowapi format)
SESSIONS_RATE_LIMIT=10/minute

# TTL эфемерных TURN-кредов (секунды)
TURN_CRED_TTL=3600